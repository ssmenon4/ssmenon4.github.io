---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageMast from "../components/PageMast.astro";
import Plate from "../components/Plate.astro";
import VideoEmbed from "../components/VideoEmbed.astro";
import { projects } from "../data/projects";

const anchor = (p: (typeof projects)[number], i: number) => p.slug ?? `p-0${i + 1}`;

const fieldLabels = ["ORCHESTRATION", "MEMORY", "EVALUATION"];
---

<BaseLayout title="Projects">
  <div class="page">
    <PageMast
      crumb="WORK"
      title="Work"
      sub="Systems that can be measured — retrieval pipelines, multi-agent engines, and the evaluation harnesses that keep them honest."
      kv={`${projects.length} PROJECTS · 2023 — ONGOING · 2 PEER-REVIEWED`}
    />

    <table class="ledger">
      {
        projects.map((p, i) => (
          <tr>
            <td class="n">P-0{i + 1}</td>
            <td>
              <a href={`#${anchor(p, i)}`}>{p.title}</a>
            </td>
            <td class="f">{p.tag.toUpperCase()}</td>
            <td class="st">
              {p.status === "ongoing" ? (
                <>
                  <span class="on">●</span> ONGOING · {p.year}
                </>
              ) : (
                <>PUBLISHED · {p.year}</>
              )}
            </td>
          </tr>
        ))
      }
    </table>

    {
      projects.map((p, i) => (
        <section id={anchor(p, i)} class="dossier">
          <h2>{p.title}</h2>
          <div class="mono dossier-line">
            {p.year} · {p.status === "ongoing" ? "ONGOING" : "PUBLISHED"} · {p.stack}
          </div>

          {p.videoId ? (
            <>
              <VideoEmbed videoId={p.videoId} title={p.title} poster={p.image} />
              <div class="plate-cap" style="text-align:right; margin-top:7px;">
                plate 1 — engine demo · click to play
              </div>
            </>
          ) : (
            <Plate caption="plate 1 — duotoned to unify with the rest of the page">
              <div style="position:relative;">
                <img
                  src={p.image}
                  alt=""
                  style="display:block; width:100%; height:340px; object-fit:cover; filter:grayscale(1) contrast(1.08) brightness(1.02);"
                />
                <div style="position:absolute; inset:0; background:var(--signal); mix-blend-mode:color; opacity:.45;" />
              </div>
            </Plate>
          )}

          {p.highlights && (
            <table class="datasheet">
              {p.highlights.map((h, i) => (
                <tr>
                  <td class="lbl mono">{fieldLabels[i] ?? h.title.split(" ")[0].toUpperCase()}</td>
                  <td class="detail">{h.detail}</td>
                </tr>
              ))}
            </table>
          )}

          {!p.highlights && <p class="dossier-desc">{p.description}</p>}

          <div class="dossier-links mono">
            {p.videoId && p.blogHref && <a href={p.blogHref}>READ THE WRITE-UP</a>}
            {!p.videoId && p.href && <a href={p.href}>PAPER ▸</a>}
          </div>
        </section>
      ))
    }
  </div>
</BaseLayout>

<style>
  .ledger {
    margin: 8px 0 34px;
  }
  .dossier {
    padding: 48px 0;
    border-top: 3px double var(--line-strong);
  }
  .dossier h2 {
    font-weight: 400;
    font-size: 26px;
    margin: 0 0 6px;
  }
  .dossier-line {
    font-size: 11.5px;
    color: var(--meta);
    letter-spacing: 0.08em;
    margin-bottom: 22px;
  }
  .dossier-desc {
    font-family: var(--font-sans);
    font-size: 14px;
    color: var(--sub);
    line-height: 1.7;
    max-width: 64ch;
    margin: 30px 0 0;
  }
  .datasheet {
    width: 100%;
    border-collapse: collapse;
    margin-top: 30px;
    font-family: var(--font-sans);
    font-size: 14px;
  }
  .datasheet td {
    padding: 11px 16px 11px 0;
    border-top: 1px solid var(--line);
    vertical-align: top;
  }
  .datasheet .lbl {
    width: 30%;
    font-size: 10.5px;
    letter-spacing: 0.1em;
    color: var(--meta);
    white-space: nowrap;
  }
  .datasheet .detail {
    color: var(--sub);
    line-height: 1.6;
    padding-right: 0;
  }
  .dossier-links {
    margin-top: 24px;
    display: flex;
    gap: 22px;
    font-size: 11.5px;
    letter-spacing: 0.08em;
  }
  .dossier-links a {
    color: var(--signal);
  }
  .dossier-links a:hover {
    color: var(--signal-bright);
  }
</style>
