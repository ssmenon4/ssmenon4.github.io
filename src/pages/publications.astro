---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageMast from "../components/PageMast.astro";
import { publications } from "../data/publications";

const years = publications.map((p) => Number(p.year));
const yearRange = Math.min(...years) === Math.max(...years)
  ? `${Math.min(...years)}`
  : `${Math.min(...years)} – ${Math.max(...years)}`;
---

<BaseLayout title="Publications">
  <div class="page">
    <PageMast
      crumb="PAPERS"
      title="Papers"
      sub="Peer-reviewed work in accessible robotics and ultraviolet astronomy."
      kv={`${publications.length} PUBLICATIONS · ${yearRange} · GOOGLE SCHOLAR ↗`}
    />

    {
      publications.map((p, i) => (
        <div class="paper">
          <div class="mono kicker">
            {p.year} · {p.kind.toUpperCase()}
          </div>
          <div class="t">{p.title}</div>
          <div class="v" set:html={p.description.replace(
            "S.S. Menon",
            "<b>Shivashankar S Menon</b>"
          )} />
          <div style="margin-top:6px;">
            <a class="doi" href={p.href} target="_blank" rel="noopener">
              doi:{p.href?.split("doi.org/")[1]}
            </a>
            &nbsp;&nbsp;
            <button type="button" class="doi cite-toggle" data-idx={i}>
              [ CITE ]
            </button>
          </div>
          <div class="plate cite-plate" data-idx={i} hidden>
            <pre class="mono cite-pre" data-idx={i}>{p.bibtex}</pre>
            <div class="plate-cap copy-note" data-idx={i}>click to copy</div>
          </div>
        </div>
      ))
    }
    <div class="plate-cap" style="text-align:left; margin-top:14px;">
      [ CITE ] flips the entry open to a BibTeX block — copy-ready, mono, one click.
    </div>
  </div>
</BaseLayout>

<style>
  .kicker {
    font-size: 10.5px;
    letter-spacing: 0.1em;
    color: var(--meta);
    margin-bottom: 5px;
  }
  .cite-toggle {
    background: none;
    border: none;
    padding: 0;
    font: inherit;
    cursor: pointer;
    color: var(--meta);
  }
  .cite-toggle:hover {
    color: var(--signal);
  }
  .cite-plate {
    margin-top: 12px;
    padding: 14px 16px;
    cursor: pointer;
  }
  .cite-pre {
    margin: 0;
    font-size: 11.5px;
    line-height: 1.6;
    color: var(--sub);
    white-space: pre-wrap;
    word-break: break-word;
  }
  .copy-note {
    margin-top: 8px;
    text-align: right;
  }
</style>

<script>
  const COPY_LABEL = "click to copy";
  const resetTimers = new Map<HTMLElement, number>();

  document.addEventListener("click", async (e) => {
    const target = e.target as HTMLElement;

    const toggle = target.closest<HTMLElement>(".cite-toggle");
    if (toggle) {
      const idx = toggle.dataset.idx;
      const plate = document.querySelector<HTMLElement>(`.cite-plate[data-idx="${idx}"]`);
      if (plate) plate.hidden = !plate.hidden;
      return;
    }

    const plate = target.closest<HTMLElement>(".cite-plate");
    if (plate) {
      const idx = plate.dataset.idx;
      const pre = plate.querySelector<HTMLElement>(`.cite-pre[data-idx="${idx}"]`);
      const note = plate.querySelector<HTMLElement>(`.copy-note[data-idx="${idx}"]`);
      if (pre && note) {
        try {
          await navigator.clipboard.writeText(pre.textContent ?? "");
          note.textContent = "copied ✓";
          const pending = resetTimers.get(note);
          if (pending !== undefined) clearTimeout(pending);
          resetTimers.set(
            note,
            window.setTimeout(() => {
              note.textContent = COPY_LABEL;
              resetTimers.delete(note);
            }, 1500),
          );
        } catch {
          /* clipboard unavailable — no-op */
        }
      }
    }
  });
</script>
