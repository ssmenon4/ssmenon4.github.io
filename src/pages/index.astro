---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import LorenzHero from "../components/LorenzHero.astro";
import StatusStrip from "../components/StatusStrip.astro";
import Plate from "../components/Plate.astro";
import { site, socials } from "../config/site";
import { projects } from "../data/projects";
import { publications } from "../data/publications";
import { nowStatus } from "../data/now";

const featured = projects.filter((p) => p.featured);

const introSentences = site.description.match(/[^.]+\.\s*/g) ?? [site.description];
const intro = introSentences.slice(0, 2).join(" ").trim();

const allPosts = await getCollection("blog", ({ data }) => !data.draft);
const seriesPosts = allPosts
  .filter((p) => p.data.series === "rag-revisited")
  .sort((a, b) => (a.data.order ?? 0) - (b.data.order ?? 0));
const nonSeriesPosts = allPosts
  .filter((p) => p.data.series !== "rag-revisited")
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const latest = nonSeriesPosts[0];

function fmtDate(d: Date) {
  return d
    .toLocaleDateString("en-US", { month: "short", day: "2-digit" })
    .toUpperCase();
}

function github() {
  return socials.find((s) => s.label === "GitHub")?.href;
}
function linkedin() {
  return socials.find((s) => s.label === "LinkedIn")?.href;
}

function pubYear(date: string) {
  const m = date.match(/\d{4}/);
  return m ? m[0] : date;
}

function doiText(href?: string) {
  if (!href) return "";
  const i = href.indexOf("doi.org/");
  return i === -1 ? href : `doi:${href.slice(i + "doi.org/".length)}`;
}

function venueFor(href?: string) {
  return publications.find((pub) => pub.href === href)?.venue ?? "";
}
---

<BaseLayout>
  <div class="page">
    <div class="mast">
      <div class="mast-fig"><LorenzHero /></div>
      <h1>Engineering AI, from research to production.</h1>
      <p>{intro}</p>
      <div class="cap mono">
        fig. 1 — lorenz attractor · σ=10, ρ=28, β=8/3 · <span class="dot">●</span> live ·
        <a href="#" id="why" style="color:var(--signal); border-bottom:1px solid var(--signal);">why?</a>
      </div>
      <div
        class="cap mono"
        id="whynote"
        style="display:none; position:static; margin-top:6px; max-width:46ch; margin-left:auto; text-align:right; line-height:1.6;"
      >
        I've been fascinated by chaos theory and the Lorenz attractor since I was a child — this is me appreciating
        its beauty and sharing it.
        <a href="https://www.reddit.com/r/explainlikeimfive/comments/o0mvog/" style="color:var(--signal);">read more ↗</a>
      </div>
    </div>

    <StatusStrip />

    <section>
      <div class="sh"><span class="no">§ 01</span><h2>Selected Work</h2><div class="rule"></div><a href="/projects">ALL PROJECTS →</a></div>

      {
        featured.map((p) => (
          <div class="entry">
            <div>
              <h3><a href={p.href ?? "/projects"}>{p.title}</a></h3>
              <p class="desc">{p.description}</p>
              {p.highlights && (
                <div class="spec">
                  {p.highlights.map((h) => (
                    <div><b>{h.title}.</b> {h.detail}</div>
                  ))}
                </div>
              )}
              <div class="links">
                {p.slug === "amphoreus-dnd" ? (
                  <>
                    <a href="/projects#amphoreus-dnd">WATCH THE DEMO ▸</a>
                    {p.blogHref && <a href={p.blogHref}>READ THE WRITE-UP</a>}
                  </>
                ) : (
                  <a href={p.href}>PAPER · {venueFor(p.href).toUpperCase()}</a>
                )}
              </div>
            </div>
            <div class="side">
              <div>
                {p.slug === "amphoreus-dnd" ? (
                  <Plate caption="fig. 2 — the turn cycle · every intent passes<br>through the orchestrator · no orbit repeats">
                    <div class="ph" style="height:120px">[fig. 2 — lemniscate mark · Task 6]</div>
                  </Plate>
                ) : p.image?.includes("AdaGen") ? (
                  <Plate caption="fig. 3 — vibration trace, cobblestone">
                    <div style="position:relative;">
                      <img
                        src="/projects/AdaGen.jpg"
                        alt=""
                        style="filter:grayscale(1) contrast(1.08) brightness(1.02); display:block; width:100%; height:120px; object-fit:cover;"
                      />
                      <div style="position:absolute; inset:0; background:var(--signal); mix-blend-mode:color; opacity:.45;" />
                    </div>
                  </Plate>
                ) : (
                  <Plate caption="fig. 4 — GALEX deep-sky field">
                    <div style="position:relative;">
                      <img
                        src="/projects/Galex.jpg"
                        alt=""
                        style="filter:grayscale(1) contrast(1.08) brightness(1.02); display:block; width:100%; height:120px; object-fit:cover;"
                      />
                      <div style="position:absolute; inset:0; background:var(--signal); mix-blend-mode:color; opacity:.45;" />
                    </div>
                  </Plate>
                )}
              </div>
              <div class="meta-col">
                <span class="yr">{p.year}</span>
                <span>{p.slug === "amphoreus-dnd" ? "ONGOING" : "PUBLISHED"}</span>
                <span>{p.tag.toUpperCase()}</span>
              </div>
            </div>
          </div>
        ))
      }
    </section>

    <section>
      <div class="sh"><span class="no">§ 02</span><h2>Writing</h2><div class="rule"></div><a href="/blog">ALL POSTS →</a></div>

      <div class="series-head">
        <h3>RAG, Revisited — field notes from 2023–24, re-read against the 2026 canon</h3>
        <span>{seriesPosts.length} PARTS · JUN 2026</span>
      </div>
      {
        seriesPosts.map((post) => (
          <div class="post">
            <span class="n">№ {String(post.data.order).padStart(2, "0")}</span>
            <span class="t"><a href={`/blog/${post.slug}`}>{post.data.title}</a></span>
            <span class="m">{fmtDate(post.data.date)}</span>
          </div>
        ))
      }

      {
        latest && (
          <div class="offcuts">
            <div class="lbl mono">LATEST</div>
            <div class="post light">
              <span class="n">✳</span>
              <span class="t"><a href={`/blog/${latest.slug}`}>{latest.data.title}</a></span>
              <span class="m">{fmtDate(latest.data.date)}</span>
            </div>
          </div>
        )
      }
    </section>

    <section>
      <div class="sh"><span class="no">§ 03</span><h2>Publications</h2><div class="rule"></div></div>
      {
        publications.map((pub) => (
          <div class="paper">
            <div class="t">{pub.title}</div>
            <div class="v">
              <em>{pub.venue}</em>, {pubYear(pub.date)} ·{" "}
              <a class="doi" href={pub.href}>{doiText(pub.href)}</a>
            </div>
          </div>
        ))
      }
    </section>

    <section>
      <div class="sh"><span class="no">§ 04</span><h2>About</h2><div class="rule"></div></div>
      <div class="about">
        <div>
          <p>I've been drawn to the same question since I first saw a Lorenz attractor: how do simple rules produce behavior you couldn't have guessed? These days I ask it of LLM agents instead of differential equations.</p>
          <p>Earlier work spanned vibration data from wheelchairs, ultraviolet light from a space telescope, and retrieval over financial text — plus a focused two years studying India's public policy and governance, which sharpened how I analyse complex, real-world problems.</p>
        </div>
        <div class="now">
          <div class="lbl">NOW</div>
          <ul>
            <li><b>Building</b> — {nowStatus.building.charAt(0)}{nowStatus.building.slice(1).toLowerCase()}: long-horizon planning &amp; coordination in agents</li>
            <li><b>Writing</b> — what comes after <em>RAG, Revisited</em></li>
            <li><b>Elsewhere</b> — <a href={github()}>GitHub</a> · <a href={linkedin()}>LinkedIn</a> · <a href={`mailto:${site.email}`}>{site.email}</a></li>
          </ul>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>

<script>
  document.addEventListener("click", (e) => {
    const target = e.target as HTMLElement | null;
    if (target && target.id === "why") {
      e.preventDefault();
      const n = document.getElementById("whynote");
      if (n) n.style.display = n.style.display === "none" ? "block" : "none";
    }
  });
</script>
