---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Plate from "../../components/Plate.astro";
import SeriesNav from "../../components/SeriesNav.astro";
import { getCollection, type CollectionEntry } from "astro:content";
import { readingTime } from "../../lib/reading-time";

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => !data.draft);
  return posts.map((post) => ({ params: { slug: post.slug }, props: { post } }));
}

type Props = { post: CollectionEntry<"blog"> };
const { post } = Astro.props;
const { Content } = await post.render();
const fmt = (d: Date) =>
  d.toLocaleDateString("en-US", { month: "long", day: "numeric", year: "numeric" });

const { heroKicker, heroPhrase, heroTagline, heroCredit, hideHero, image, category, date, title } =
  post.data;
---

<BaseLayout title={title} description={post.data.description} image={image}>
  <div class="page article-page">
    <a href="/blog" class="back mono">&larr; WRITING</a>

    <header class="article-head">
      {heroKicker && <div class="kicker mono">{heroKicker}</div>}
      <h1>{heroPhrase || title}</h1>
      {heroTagline && <p class="tagline">{heroTagline}</p>}
      {
        image && !hideHero && (
          <Plate caption={heroCredit ? `photo: ${heroCredit}` : `fig. — ${title}`}>
            <img
              src={image}
              alt={title}
              style="display:block; width:100%; height:auto; object-fit:cover;"
            />
          </Plate>
        )
      }
      <div class="byline mono">
        {fmt(date)} &middot; {readingTime(post.body)} MIN &middot; {category.toUpperCase()}
      </div>
    </header>

    <article class="prose-journal">
      {heroPhrase && <p class="real-title">{title}</p>}
      <Content />
    </article>

    <SeriesNav post={post} />
  </div>
</BaseLayout>
