---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageMast from "../../components/PageMast.astro";
import { getCollection } from "astro:content";
import { readingTime } from "../../lib/reading-time";

const posts = (await getCollection("blog", ({ data }) => !data.draft));
const series = posts.filter(p => p.data.series === "rag-revisited")
  .sort((a, b) => (a.data.order ?? 0) - (b.data.order ?? 0));
const standalone = posts.filter(p => p.data.series !== "rag-revisited")
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const byYear = Object.entries(Object.groupBy(standalone, p => p.data.date.getFullYear()))
  .sort((a, b) => Number(b[0]) - Number(a[0]));
const fmt = (d: Date) => d.toLocaleDateString("en-US", { month: "short", day: "2-digit" }).toUpperCase();
const seriesCount = new Set(posts.map(p => p.data.series).filter(Boolean)).size;
const earliest = posts.reduce((a, b) => (a.data.date < b.data.date ? a : b));
const since = earliest.data.date
  .toLocaleDateString("en-US", { month: "short", year: "numeric" })
  .toUpperCase();
---

<BaseLayout title="Writing">
  <div class="page">
    <PageMast
      crumb="WRITING"
      title="Writing"
      sub="Blurbs on retrieval, agents, and evaluation — plus the occasional off-the-clock note."
      kv={`${posts.length} POSTS · ${seriesCount} SERIES · SINCE ${since}`}
    />

    {
      series.length > 0 && (
        <>
          <div class="series-head">
            <h3>RAG, Revisited</h3>
            <span>SERIES · {series.length} PARTS · COMPLETE</span>
          </div>
          {
            series.map((post) => (
              <div class="wpost">
                <span class="n">№ {String(post.data.order ?? 0).padStart(2, "0")}</span>
                <span class="t">
                  <a href={`/blog/${post.slug}`}>{post.data.title}</a>
                </span>
                <span class="m">{fmt(post.data.date)} · {readingTime(post.body)} MIN</span>
                {post.data.heroPhrase && <span class="ph">{post.data.heroPhrase}</span>}
              </div>
            ))
          }
        </>
      )
    }

    {
      byYear.map(([year, yearPosts]) => (
        <div class="offcuts">
          <div class="lbl mono">STANDALONE · {year}</div>
          {
            yearPosts!.map((post) => (
              <div class="wpost">
                <span class="n mono" style="color:var(--signal);">✳</span>
                <span class="t">
                  <a href={`/blog/${post.slug}`}>{post.data.title}</a>
                </span>
                <span class="m">{fmt(post.data.date)} · {readingTime(post.body)} MIN</span>
                {post.data.heroPhrase && <span class="ph">{post.data.heroPhrase}</span>}
              </div>
            ))
          }
        </div>
      ))
    }
  </div>
</BaseLayout>
