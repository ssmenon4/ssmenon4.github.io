---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageMast from "../components/PageMast.astro";
import { experience, education, skills, approach, resumePdf } from "../data/resume";
import { buildInfo } from "../lib/build-info";

const { lastCommitISO } = buildInfo();
const revised = new Date(lastCommitISO)
  .toLocaleDateString("en-US", { month: "short", year: "numeric" })
  .toUpperCase();
---

<BaseLayout title="Resume">
  <div class="page">
    <PageMast crumb="RESUME" title="Resume" sub={approach}>
      <Fragment slot="kv">
        LAST REVISED {revised}
        {resumePdf && (
          <>
            {" "}· <a href={resumePdf}>PDF ↓</a>
          </>
        )}
      </Fragment>
    </PageMast>

    <section>
      <div class="sh"><span class="no">01</span><h2>Experience</h2><div class="rule"></div></div>
      {
        experience.map((job) => (
          <div class="cv">
            <div class="when mono">
              {job.period}
              {job.tag && <span class="tag">{job.tag.toUpperCase()}</span>}
            </div>
            <div>
              <h4>{job.role}</h4>
              <div class="org">{job.org}</div>
              <p>{job.summary}</p>
              {job.highlights && (
                <ul>
                  {job.highlights.map((h) => (
                    <li>{h}</li>
                  ))}
                </ul>
              )}
            </div>
          </div>
        ))
      }
    </section>

    <section>
      <div class="sh"><span class="no">02</span><h2>Education</h2><div class="rule"></div></div>
      {
        education.map((ed) => (
          <div class="cv">
            <div class="when mono">{ed.period}</div>
            <div>
              <h4>{ed.role}</h4>
              <div class="org">{ed.org}</div>
              <p>{ed.summary}</p>
            </div>
          </div>
        ))
      }
    </section>

    <section>
      <div class="sh"><span class="no">03</span><h2>Skills</h2><div class="rule"></div></div>
      {
        skills.map((s) => (
          <div class="skillrow">
            <div class="g">{s.group.toUpperCase()}</div>
            <div class="i">{s.items.join(" · ").toUpperCase()}</div>
          </div>
        ))
      }
    </section>
  </div>
</BaseLayout>
