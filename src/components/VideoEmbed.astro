---
/**
 * Click-to-play YouTube facade. Shows a duotoned poster + play affordance and only
 * loads the (privacy-enhanced) iframe once the visitor clicks — no third-party assets
 * until then. On click, every duotone/filter element is removed together with the
 * facade so the injected iframe plays completely unfiltered.
 */
interface Props {
  videoId: string;
  title: string;
  /** Optional custom poster; defaults to YouTube's thumbnail for this video. */
  poster?: string;
}
const { videoId, title, poster } = Astro.props;
const posterSrc = poster ?? `https://i.ytimg.com/vi/${videoId}/maxresdefault.jpg`;
---

<div class="video-embed plate" style="position:relative;" data-video-id={videoId} data-title={title}>
  <button type="button" class="facade" aria-label={`Play demo video: ${title}`}>
    <img
      src={posterSrc}
      alt={`${title} demo thumbnail`}
      class="video-poster"
      loading="lazy"
    />
    <div class="video-duotone"></div>
    <span class="video-play">▶</span>
  </button>
</div>

<style>
  .video-embed .facade {
    position: relative;
    display: block;
    width: 100%;
    aspect-ratio: 16 / 9;
    padding: 0;
    margin: 0;
    border: 0;
    background: none;
    cursor: pointer;
  }
  .video-poster {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(1) contrast(1.08) brightness(1.02);
  }
  .video-duotone {
    position: absolute;
    inset: 0;
    background: var(--signal);
    mix-blend-mode: color;
    opacity: 0.45;
  }
  .video-play {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    width: 54px;
    height: 54px;
    border: 1px solid var(--signal);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--signal);
    font-size: 18px;
  }
  .video-embed iframe {
    display: block;
    width: 100%;
    height: 100%;
    aspect-ratio: 16 / 9;
    border: 0;
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>(".video-embed").forEach((wrap) => {
    const facade = wrap.querySelector<HTMLButtonElement>(".facade");
    const videoId = wrap.dataset.videoId;
    const title = wrap.dataset.title ?? "";
    if (!facade || !videoId) return;

    facade.addEventListener(
      "click",
      () => {
        const iframe = document.createElement("iframe");
        iframe.src = `https://www.youtube-nocookie.com/embed/${videoId}?autoplay=1&rel=0`;
        iframe.title = title;
        iframe.allow = "autoplay; encrypted-media; picture-in-picture; fullscreen";
        iframe.allowFullscreen = true;
        // Remove the entire duotoned facade (poster, overlay, play affordance)
        // together so the injected iframe plays completely unfiltered.
        facade.replaceWith(iframe);
      },
      { once: true },
    );
  });
</script>
