---
/**
 * Series navigation for posts that belong to a `series`.
 * Derives everything from frontmatter: the hub is the member at `order: 0`,
 * its title is the series title, and the remaining members are the ordered
 * parts. Renders a "back to overview" line plus prev/next hairline rows.
 * Renders nothing on the hub post itself or on posts with no series.
 */
import { getCollection, type CollectionEntry } from "astro:content";

interface Props {
  post: CollectionEntry<"blog">;
}
const { post } = Astro.props;

type Entry = CollectionEntry<"blog">;
let ctx:
  | {
      seriesTitle: string;
      hubSlug: string;
      prev: Entry | null;
      next: Entry | null;
    }
  | null = null;

const seriesId = post.data.series;
if (seriesId) {
  const members = (
    await getCollection("blog", ({ data }) => data.series === seriesId && !data.draft)
  ).sort((a, b) => (a.data.order ?? 0) - (b.data.order ?? 0));

  const hub = members.find((m) => (m.data.order ?? 0) === 0) ?? members[0];
  const parts = members.filter((m) => m.slug !== hub.slug);
  const chain = [hub, ...parts];
  const idx = chain.findIndex((m) => m.slug === post.slug);
  const isHub = post.slug === hub.slug;

  if (!isHub && idx !== -1) {
    ctx = {
      seriesTitle: hub.data.title,
      hubSlug: hub.slug,
      prev: idx > 0 ? chain[idx - 1] : null,
      next: idx < chain.length - 1 ? chain[idx + 1] : null,
    };
  }
}

const numLabel = (p: Entry) => `№ ${String(p.data.order ?? 0).padStart(2, "0")}`;
const wordLabel = (p: Entry) => p.slug.toUpperCase();
---

{
  ctx && (
    <nav aria-label="Series navigation" class="series-nav mono">
      {ctx.prev ? (
        <a href={`/blog/${ctx.prev.slug}`} class="snrow">
          &larr; {numLabel(ctx.prev)} &middot; {wordLabel(ctx.prev)}
        </a>
      ) : (
        <div class="snrow" />
      )}

      <a href={`/blog/${ctx.hubSlug}`} class="snrow hub">
        SERIES HUB
      </a>

      {ctx.next ? (
        <a href={`/blog/${ctx.next.slug}`} class="snrow next">
          {numLabel(ctx.next)} &middot; {wordLabel(ctx.next)} &rarr;
        </a>
      ) : (
        <div class="snrow" />
      )}
    </nav>
  )
}
