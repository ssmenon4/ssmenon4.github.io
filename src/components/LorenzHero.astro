---
/**
 * Interactive Lorenz Attractor ("chaos butterfly").
 *
 * - Slowly turntable-rotates; "breathing" = the colour fades and intensifies
 *   (line opacity pulses), the geometry itself does not scale.
 * - A few "comet" particles flow along the trajectory, each dragging a fading
 *   tail (welded to the curve, so it spins with it) and led by a glossy sphere
 *   head — so the chaotic lobe-shifting is visible at a glance.
 * - Sits inset within a rotating 3D lattice of dots that conveys depth.
 * - Drag (mouse / touch) to reorient freely; 3s after the last drag it eases
 *   back to the default tilt and resumes auto-rotation.
 * - Colour gradient + dot colour adapt to light / dark theme (driven by the
 *   `data-theme` attribute on <html>, watched via MutationObserver, and read
 *   from CSS custom properties at runtime).
 *
 * Vanilla canvas — no 3D library, to match the project's zero-JS-deps setup.
 */
---

<div
  class="lorenz-host w-full h-full relative cursor-grab active:cursor-grabbing select-none"
  data-lorenz
>
  <canvas class="lorenz-canvas w-full h-full block" style="touch-action: none;"></canvas>
</div>

<script>
  type Stop = [number, number, number];

  const SIGMA = 10;
  const RHO = 28;
  const BETA = 8 / 3;

  // Read a hex colour custom property (e.g. "--trail") off <html> at
  // runtime, so the palette always tracks the active theme's tokens.
  function cssRGB(name: string): Stop {
    const v = getComputedStyle(document.documentElement).getPropertyValue(name).trim();
    const n = parseInt(v.slice(1), 16);
    return [(n >> 16) & 255, (n >> 8) & 255, n & 255];
  }

  const lerp = (a: number, b: number, t: number) => a + (b - a) * t;

  function sampleStops(stops: Stop[], t: number): Stop {
    const n = stops.length - 1;
    const clamped = Math.max(0, Math.min(1, t));
    const scaled = clamped * n;
    const i = Math.min(n - 1, Math.floor(scaled));
    const f = scaled - i;
    const a = stops[i];
    const b = stops[i + 1];
    return [
      Math.round(lerp(a[0], b[0], f)),
      Math.round(lerp(a[1], b[1], f)),
      Math.round(lerp(a[2], b[2], f)),
    ];
  }

  function initLorenz(host: HTMLElement) {
    const canvas = host.querySelector<HTMLCanvasElement>("canvas.lorenz-canvas");
    if (!canvas) return;
    const ctx = canvas.getContext("2d");
    if (!ctx) return;

    const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const isMobile = window.matchMedia("(max-width: 768px)").matches;

    // ---- Generate the attractor once. -----------------------------------
    const N = isMobile ? 2800 : 5200;
    const dt = 0.007;
    const xs = new Float32Array(N);
    const ys = new Float32Array(N);
    const zs = new Float32Array(N);

    let x = 0.01,
      y = 0,
      z = 0;
    // Discard the transient that flies in from the origin.
    for (let i = 0; i < 400; i++) {
      x += SIGMA * (y - x) * dt;
      y += (x * (RHO - z) - y) * dt;
      z += (x * y - BETA * z) * dt;
    }
    let cz = 0;
    for (let i = 0; i < N; i++) {
      const dx = SIGMA * (y - x);
      const dy = x * (RHO - z) - y;
      const dz = x * y - BETA * z;
      x += dx * dt;
      y += dy * dt;
      z += dz * dt;
      xs[i] = x;
      ys[i] = y;
      zs[i] = z;
      cz += z;
    }
    cz /= N; // centroid z (x,y centroids ~ 0)

    // Enlarge the attractor ~20% (so it spans a wider slice of the lattice).
    const ATTRACTOR_SCALE = 1.2;
    for (let i = 0; i < N; i++) {
      xs[i] *= ATTRACTOR_SCALE;
      ys[i] *= ATTRACTOR_SCALE;
      zs[i] *= ATTRACTOR_SCALE;
    }
    cz *= ATTRACTOR_SCALE;

    // ---- Per-sample speed |d/dt| (normalised 0..1) for velocity glow. ----
    // Consecutive samples ARE the time-evolution, so a central difference
    // gives the true local velocity: fast at the centre crossings, slow at
    // the wing tips. Particles use this to glow hot where the flow is fast.
    const spd = new Float32Array(N);
    let maxSpd = 1e-6;
    for (let i = 0; i < N; i++) {
      const i0 = i > 0 ? i - 1 : i;
      const i1 = i < N - 1 ? i + 1 : i;
      const ddx = xs[i1] - xs[i0];
      const ddy = ys[i1] - ys[i0];
      const ddz = zs[i1] - zs[i0];
      const s = Math.sqrt(ddx * ddx + ddy * ddy + ddz * ddz);
      spd[i] = s;
      if (s > maxSpd) maxSpd = s;
    }
    for (let i = 0; i < N; i++) spd[i] /= maxSpd;

    // ---- 3D dot lattice that frames the attractor. ----------------------
    // Constant spacing -> a bigger lattice simply means more dots / volume.
    const SPACING = 18;
    const DIV = 5; // points-per-edge minus one -> (DIV+1)^3 = 216 dots
    const G = (SPACING * DIV) / 2; // half-extent of the lattice cube
    const dotX: number[] = [];
    const dotY: number[] = [];
    const dotZ: number[] = [];
    for (let i = 0; i <= DIV; i++) {
      for (let j = 0; j <= DIV; j++) {
        for (let k = 0; k <= DIV; k++) {
          dotX.push(-G + (2 * G * i) / DIV);
          dotY.push(-G + (2 * G * j) / DIV);
          dotZ.push(-G + (2 * G * k) / DIV);
        }
      }
    }
    const DOTS = dotX.length;
    const dpx = new Float32Array(DOTS);
    const dpy = new Float32Array(DOTS);
    const ddepth = new Float32Array(DOTS);

    // Fit the canvas to the ATTRACTOR's worst-case radius so it fills the
    // frame (~80%); the lattice extends past the edges for an immersive feel.
    let R = 1;
    for (let i = 0; i < N; i++) {
      const dzc = zs[i] - cz;
      const r = Math.sqrt(xs[i] * xs[i] + ys[i] * ys[i] + dzc * dzc);
      if (r > R) R = r;
    }
    const R_DOT = Math.sqrt(3) * G; // lattice extent, for dot depth shading

    // Precompute colour per drawing bucket + dot colour.
    const BUCKETS = isMobile ? 70 : 110;
    let colors: string[] = [];
    let palette: Stop[] = [];
    let dotRGB: Stop = [0, 0, 0];
    let isDark = false;
    const detectDark = () => {
      const attr = document.documentElement.getAttribute("data-theme");
      if (attr === "dark") return true;
      if (attr === "light") return false;
      return window.matchMedia("(prefers-color-scheme: dark)").matches;
    };
    const buildColors = () => {
      isDark = detectDark();
      palette = [cssRGB("--trail"), cssRGB("--signal"), cssRGB("--signal-bright")];
      colors = [];
      for (let b = 0; b < BUCKETS; b++) {
        const rgb = sampleStops(palette, b / (BUCKETS - 1));
        colors.push(`rgb(${rgb[0]}, ${rgb[1]}, ${rgb[2]})`);
      }
      dotRGB = cssRGB("--line-strong");
    };
    buildColors();

    // ---- View state ------------------------------------------------------
    const DEFAULT_PITCH = 0.5236; // 30° forward tilt
    const AUTO_YAW_SPEED = 0.16; // rad / s
    const RETURN_DELAY = 3000; // ms after last drag before re-orienting

    let yaw = 0;
    let pitch = DEFAULT_PITCH;
    let dragging = false;
    let lastPointerX = 0;
    let lastPointerY = 0;
    let lastInteraction = -1e9; // far in the past -> auto-rotate from start

    // ---- Flowing comet particles -----------------------------------------
    // Each is just a (fractional) index walking the precomputed trajectory, so
    // it rides the real dynamical flow. Kept few and staggered so the viewer
    // can follow each one picking a lobe (the chaotic lobe-shifting).
    const PARTICLES = 3;
    const HEAD_SPEED = isMobile ? 95 : 135; // samples / second
    const heads = new Float32Array(PARTICLES);
    for (let p = 0; p < PARTICLES; p++) heads[p] = (p / PARTICLES) * N;

    // Each head drags a comet tail of the samples just behind it. Because head
    // speed is constant in samples/sec, a fixed sample window == a fixed time
    // window. The tail is drawn through the curve's own samples, so it stays
    // welded to the attractor and spins with it.
    const EXPOSURE_SECONDS = 1.5; // how long the trail lingers (tail length)
    const TAIL = Math.round(EXPOSURE_SECONDS * HEAD_SPEED); // samples behind head

    let cssW = 0;
    let cssH = 0;

    const resize = () => {
      const rect = host.getBoundingClientRect();
      cssW = Math.max(1, rect.width);
      cssH = Math.max(1, rect.height);
      const dpr = Math.min(window.devicePixelRatio || 1, 2);
      canvas.width = Math.round(cssW * dpr);
      canvas.height = Math.round(cssH * dpr);
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    };
    resize();
    const ro = new ResizeObserver(() => {
      resize();
      startLoop(); // redraw (and re-park) the reduced-motion loop
    });
    ro.observe(host);

    // ---- Interaction -----------------------------------------------------
    const onDown = (e: PointerEvent) => {
      dragging = true;
      lastPointerX = e.clientX;
      lastPointerY = e.clientY;
      lastInteraction = performance.now();
      canvas.setPointerCapture(e.pointerId);
      startLoop(); // wake the parked reduced-motion loop for the drag
    };
    const onMove = (e: PointerEvent) => {
      if (!dragging) return;
      const dx = e.clientX - lastPointerX;
      const dy = e.clientY - lastPointerY;
      lastPointerX = e.clientX;
      lastPointerY = e.clientY;
      yaw += dx * 0.01;
      pitch += dy * 0.01;
      pitch = Math.max(-1.45, Math.min(1.45, pitch));
      lastInteraction = performance.now();
    };
    const onUp = (e: PointerEvent) => {
      if (!dragging) return;
      dragging = false;
      lastInteraction = performance.now();
      try {
        canvas.releasePointerCapture(e.pointerId);
      } catch {}
    };
    canvas.addEventListener("pointerdown", onDown);
    canvas.addEventListener("pointermove", onMove);
    canvas.addEventListener("pointerup", onUp);
    canvas.addEventListener("pointercancel", onUp);

    // React to theme toggle.
    const themeObserver = new MutationObserver(() => {
      buildColors();
      startLoop(); // redraw (and re-park) the reduced-motion loop
    });
    themeObserver.observe(document.documentElement, {
      attributes: true,
      attributeFilter: ["data-theme"],
    });
    // No explicit data-theme means the page follows the OS setting, so also
    // react to the media query flipping (e.g. system dark mode toggled).
    const darkMedia = window.matchMedia("(prefers-color-scheme: dark)");
    const onMediaChange = () => {
      if (!document.documentElement.getAttribute("data-theme")) {
        buildColors();
        startLoop(); // redraw (and re-park) the reduced-motion loop
      }
    };
    darkMedia.addEventListener("change", onMediaChange);

    // ---- Render loop -----------------------------------------------------
    const px = new Float32Array(N);
    const py = new Float32Array(N);
    let lastT = performance.now();
    let rafId = 0;

    const frame = (now: number) => {
      // Schedule the next frame FIRST, so a transient error in the body (e.g.
      // during the initial layout/font settle) can't strand the loop and leave
      // a blank canvas. Visibility pausing is handled by start/stopLoop below.
      rafId = requestAnimationFrame(frame);

      const dtFrame = Math.min(0.05, (now - lastT) / 1000);
      lastT = now;

      if (!dragging) {
        const since = now - lastInteraction;
        if (since > RETURN_DELAY) {
          // Ease tilt back to default and resume turntable rotation.
          pitch += (DEFAULT_PITCH - pitch) * Math.min(1, dtFrame * 2.2);
          if (!reduceMotion) yaw += AUTO_YAW_SPEED * dtFrame;
        }
        // else: hold the user's orientation during the grace period.
      }

      // Advance comet heads along the trajectory (wrap at the end).
      if (!reduceMotion) {
        for (let p = 0; p < PARTICLES; p++) {
          heads[p] += HEAD_SPEED * dtFrame;
          if (heads[p] >= N) heads[p] -= N;
        }
      }

      // Rail opacity driver. Under reduced motion the rail is pinned at full,
      // steady opacity (no breathing — the attractor renders complete and
      // static); in animated mode it's pinned at minimum and the comets carry
      // the motion instead.
      const pulse = reduceMotion ? 1 : 0;
      const scale = (Math.min(cssW, cssH) * 0.5 * 0.85) / R;
      const ox = cssW / 2;
      const oy = cssH / 2;

      const cy = Math.cos(yaw);
      const sy = Math.sin(yaw);
      const cp = Math.cos(pitch);
      const sp = Math.sin(pitch);

      // Project attractor.
      for (let i = 0; i < N; i++) {
        const ax = xs[i];
        const ay = ys[i];
        const az = zs[i] - cz;
        const X = ax * cy - ay * sy;
        const Y = ax * sy + ay * cy;
        const Z2 = Y * sp + az * cp; // vertical (screen up = negative)
        px[i] = ox + X * scale;
        py[i] = oy - Z2 * scale;
      }

      // Project lattice dots (+ depth for size/alpha & draw order).
      for (let i = 0; i < DOTS; i++) {
        const ax = dotX[i];
        const ay = dotY[i];
        const az = dotZ[i];
        const X = ax * cy - ay * sy;
        const Y = ax * sy + ay * cy;
        const Z2 = Y * sp + az * cp;
        dpx[i] = ox + X * scale;
        dpy[i] = oy - Z2 * scale;
        ddepth[i] = Y * cp - az * sp; // + = farther from camera
      }

      ctx.clearRect(0, 0, cssW, cssH);
      ctx.lineCap = "round";
      ctx.lineJoin = "round";

      // Far dots (behind the attractor).
      drawDots(false);

      // Attractor "rail": a wide low-alpha bloom underlay ("lighter" on dark /
      // "multiply" on light) plus a crisp thin line on top, both driven by
      // `pulse`. Under reduced motion they breathe; in animated mode they're a
      // faint static "ghost rail" the comets ride over (the hazy bloom is shrunk
      // hard there so the rail still reads crisp).
      const perBucket = N / BUCKETS;
      ctx.globalCompositeOperation = isDark ? "lighter" : "multiply";
      ctx.globalAlpha = reduceMotion ? lerp(0.04, 0.28, pulse) : lerp(0.03, 0.2, pulse);
      ctx.lineWidth = reduceMotion ? (isMobile ? 4.5 : 6) : isMobile ? 2.8 : 3.6;
      drawPath(perBucket);
      ctx.globalCompositeOperation = "source-over";
      ctx.globalAlpha = reduceMotion ? lerp(0.32, 0.8, pulse) : lerp(0.16, 0.42, pulse);
      ctx.lineWidth = isMobile ? 1.3 : 1.7;
      drawPath(perBucket);

      // Glowing comet tails, welded to the spinning curve (skipped if reduced).
      if (!reduceMotion) renderTrail();

      // Near dots (in front) — completes the "inset in a lattice" depth cue.
      drawDots(true);

      ctx.globalAlpha = 1;

      // Under reduced motion nothing animates on its own, so once any
      // drag-driven tilt has settled back, park the loop entirely (no rAF
      // keeps running). Interaction / resize / theme changes call startLoop()
      // to redraw, and the loop parks itself again after settling.
      if (
        reduceMotion &&
        !dragging &&
        now - lastInteraction > RETURN_DELAY &&
        Math.abs(pitch - DEFAULT_PITCH) < 0.001
      ) {
        cancelAnimationFrame(rafId);
        rafId = 0;
      }
    };

    function drawDots(near: boolean) {
      const [r, g, b] = dotRGB;
      for (let i = 0; i < DOTS; i++) {
        if ((ddepth[i] < 0) !== near) continue;
        const t = Math.max(0, Math.min(1, ddepth[i] / R_DOT / 2 + 0.5)); // 0 near, 1 far
        const radius = lerp(2.0, 0.7, t);
        const alpha = lerp(0.55, 0.06, t);
        ctx!.globalAlpha = alpha;
        ctx!.fillStyle = `rgb(${r}, ${g}, ${b})`;
        ctx!.beginPath();
        ctx!.arc(dpx[i], dpy[i], radius, 0, Math.PI * 2);
        ctx!.fill();
      }
    }

    // Draw each head's tail as a few CONNECTED chunks (caps only at chunk
    // ends, never per-sample) so the line stays smooth and never beads. The
    // fade is applied per chunk along the real curve: transparent at the tail,
    // bright at the head. Plain source-over so revisits can't bloom to white.
    const CHUNKS = 14;
    const smoothstep = (t: number) => t * t * (3 - 2 * t);

    function renderTrail() {
      ctx!.globalCompositeOperation = "source-over";
      ctx!.lineCap = "round";
      ctx!.lineJoin = "round";
      const wMax = isMobile ? 2.4 : 3.2;

      for (let p = 0; p < PARTICLES; p++) {
        const hi = Math.floor(heads[p]);
        const tailStart = Math.max(0, hi - TAIL);
        const span = hi - tailStart;
        if (span < CHUNKS) continue;
        const per = span / CHUNKS;

        for (let c = 0; c < CHUNKS; c++) {
          const a0 = tailStart + Math.floor(c * per);
          const a1 = tailStart + Math.floor((c + 1) * per); // shared with next
          if (a1 <= a0) continue;
          const recency = (c + 0.5) / CHUNKS; // 0 tail -> 1 head
          const env = smoothstep(recency); // hold bright near head, then cool
          const mid = (a0 + a1) >> 1;
          const ci = Math.min(BUCKETS - 1, Math.floor((mid / N) * BUCKETS));
          ctx!.strokeStyle = colors[ci];
          ctx!.globalAlpha = 0.12 + 0.88 * env;
          ctx!.lineWidth = lerp(0.7, wMax, env) * (0.7 + 0.5 * spd[mid]);
          ctx!.beginPath();
          ctx!.moveTo(px[a0], py[a0]);
          for (let i = a0 + 1; i <= a1; i++) ctx!.lineTo(px[i], py[i]);
          ctx!.stroke();
        }
      }

      // Head markers: a glossy little sphere per particle so the viewer can
      // track each one (and watch it pick a lobe). An offset highlight + dark
      // terminator give it a 3D read; a soft halo lifts it off the rail.
      const pal = palette;
      const baseR = isMobile ? 3 : 4.5;
      for (let p = 0; p < PARTICLES; p++) {
        const hi = Math.floor(heads[p]);
        const s = spd[hi];
        const cx = px[hi];
        const cy = py[hi];
        const R = baseR + (isMobile ? 1.5 : 2) * s; // a touch bigger when fast
        const [cr, cg, cb] = sampleStops(pal, hi / (N - 1));

        // Soft halo (additive on dark for glow).
        ctx!.globalCompositeOperation = isDark ? "lighter" : "source-over";
        const halo = ctx!.createRadialGradient(cx, cy, 0, cx, cy, R * 2.6);
        halo.addColorStop(0, `rgba(${cr}, ${cg}, ${cb}, 0.4)`);
        halo.addColorStop(1, `rgba(${cr}, ${cg}, ${cb}, 0)`);
        ctx!.fillStyle = halo;
        ctx!.globalAlpha = 1;
        ctx!.beginPath();
        ctx!.arc(cx, cy, R * 2.6, 0, Math.PI * 2);
        ctx!.fill();

        // Shaded sphere body (source-over so it reads solid, not blown out).
        ctx!.globalCompositeOperation = "source-over";
        const sph = ctx!.createRadialGradient(
          cx - R * 0.35,
          cy - R * 0.35,
          R * 0.1,
          cx,
          cy,
          R,
        );
        sph.addColorStop(0, "rgba(255, 250, 238, 1)"); // specular highlight
        sph.addColorStop(0.45, `rgb(${cr}, ${cg}, ${cb})`);
        sph.addColorStop(
          1,
          `rgb(${Math.round(cr * 0.4)}, ${Math.round(cg * 0.4)}, ${Math.round(cb * 0.4)})`,
        ); // shaded terminator
        ctx!.fillStyle = sph;
        ctx!.beginPath();
        ctx!.arc(cx, cy, R, 0, Math.PI * 2);
        ctx!.fill();
      }
      ctx!.globalCompositeOperation = "source-over";
      ctx!.globalAlpha = 1;
    }

    function drawPath(perBucket: number) {
      for (let b = 0; b < BUCKETS; b++) {
        const start = Math.floor(b * perBucket);
        const end = Math.min(N - 1, Math.floor((b + 1) * perBucket));
        if (end <= start) continue;
        ctx!.strokeStyle = colors[b];
        ctx!.beginPath();
        ctx!.moveTo(px[start], py[start]);
        for (let i = start + 1; i <= end; i++) {
          ctx!.lineTo(px[i], py[i]);
        }
        ctx!.stroke();
      }
    }

    const startLoop = () => {
      if (rafId) return;
      lastT = performance.now();
      rafId = requestAnimationFrame(frame);
    };
    const stopLoop = () => {
      if (!rafId) return;
      cancelAnimationFrame(rafId);
      rafId = 0;
    };

    // Pause when off-screen to save battery; resume when back in view.
    const io = new IntersectionObserver((entries) => {
      const visible = entries[entries.length - 1].isIntersecting;
      if (visible) startLoop();
      else stopLoop();
    });
    io.observe(host);
    startLoop();
  }

  function start() {
    document.querySelectorAll<HTMLElement>("[data-lorenz]").forEach(initLorenz);
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", start);
  } else {
    start();
  }
</script>
