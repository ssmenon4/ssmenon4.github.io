---
/**
 * Small pill marking a blog-index card as part of a series. Renders nothing
 * when `label` is null, so callers can pass a helper result unconditionally.
 */
import Icon from "./Icon.astro";

interface Props {
  label: string | null;
}
const { label } = Astro.props;
---

{
  label && (
    <span class="inline-flex items-center gap-xs bg-surface-container py-xs px-sm rounded-full font-label-sm text-label-sm text-primary">
      <Icon name="collections_bookmark" size={14} />
      {label}
    </span>
  )
}
