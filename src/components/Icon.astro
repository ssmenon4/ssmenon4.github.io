---
/** Thin wrapper over Material Symbols. Usage: <Icon name="arrow_forward" /> */
interface Props {
  name: string;
  class?: string;
  size?: number | string;
  fill?: 0 | 1;
}
const { name, class: className = "", size, fill } = Astro.props;
const style = [
  size ? `font-size:${typeof size === "number" ? size + "px" : size}` : "",
  fill !== undefined ? `font-variation-settings:'FILL' ${fill}` : "",
]
  .filter(Boolean)
  .join(";");
---

<span class:list={["material-symbols-outlined", className]} style={style} aria-hidden="true">{name}</span>
